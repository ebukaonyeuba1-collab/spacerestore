  --black:#000000; --text:#111827;     --body:#4B5563;    --muted:#9CA3AF;
  --white:#fff;    --cream:#F8F9FC;    --line:rgba(34,63,129,.1);
  --sh-sm:0 2px 12px rgba(0,0,0,.07);
  --sh-md:0 8px 40px rgba(0,0,0,.10);
  --sh-lg:0 20px 72px rgba(0,0,0,.14);
  --r:12px; --r-lg:22px;
