.ft-col ul{list-style:none;display:flex;flex-direction:column;gap:11px}
.ft-col a{font-size:14px;color:rgba(255,255,255,.42);transition:color .2s}
.ft-col a:hover{color:var(–green)}
.ft-ci{display:flex;align-items:center;gap:10px}
.ft-ci span:first-child{font-size:16px;flex-shrink:0}
.ft-ci a,.ft-ci p{font-size:14px;color:rgba(255,255,255,.42)}
.ft-ci a:hover{color:var(–green)}
.ft-bot{padding:22px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
.ft-bot p{font-size:12.5px;color:rgba(255,255,255,.2)}
.ft-bl{display:flex;gap:22px}
.ft-bl a{font-size:12.5px;color:rgba(255,255,255,.2);transition:color .2s}
.ft-bl a:hover{color:var(–green)}

/* WA */
.wa{position:fixed;bottom:28px;right:28px;z-index:800;width:58px;height:58px;border-radius:50%;
background:#25D366;box-shadow:0 6px 28px rgba(37,211,102,.45);display:flex;align-items:center;
justify-content:center;animation:wab 3s ease-in-out infinite;transition:transform .2s}
.wa:hover{transform:scale(1.1)!important;animation:none}
.wa svg{width:28px;height:28px;fill:#fff}
@keyframes wab{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-7px)}}

/* DIVIDER */
.stripe{height:4px;background:linear-gradient(90deg,var(–green) 0%,var(–navy) 50%,var(–black) 100%)}

