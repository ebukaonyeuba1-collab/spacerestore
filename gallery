.fg input::placeholder,.fg textarea::placeholder{color:var(–muted)}
.fg textarea{min-height:130px;resize:vertical}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:18px}

/* FOOTER */
footer{background:var(–black);padding:80px 0 0}
.ft{display:grid;grid-template-columns:2fr 1fr 1fr 1.5fr;gap:52px;
