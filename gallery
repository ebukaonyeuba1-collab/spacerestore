font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(–green)}
.tag::before{content:’’;width:18px;height:2px;background:var(–green);border-radius:2px}
h1{font-family:var(–fd);font-size:clamp(40px,5.5vw,78px);font-weight:800;line-height:1.06;letter-spacing:-1.5px}
h2{font-family:var(–fd);font-size:clamp(30px,3.8vw,54px);font-weight:700;line-height:1.1;letter-spacing:-.8px}
h3{font-family:var(–fd);font-size:clamp(20px,2.4vw,28px);font-weight:600;line-height:1.2}
.sub{font-size:clamp(15px,1.5vw,18px);color:var(–body);line-height:1.85;font-weight:300}
em{color:var(–green);font-style:italic}
.white{color:#fff} .white em{color:#57BC74}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:9px;padding:15px 32px;border-radius:50px;
font-size:14px;font-weight:600;letter-spacing:.3px;border:none;cursor:pointer;
transition:all .25s ease;font-family:var(–ff)}
.btn-green{background:var(–green);color:#fff;box-shadow:0 6px 24px rgba(87,188,116,.35)}
.btn-green:hover{background:var(–green-dk);transform:translateY(-2px);box-shadow:0 12px 36px rgba(87,188,116,.4)}
.btn-navy{background:var(–navy);color:#fff;box-shadow:0 6px 24px rgba(34,63,129,.22)}
.btn-navy:hover{background:var(–navy-lt);transform:translateY(-2px)}
.btn-black{background:#000;color:#fff;box-shadow:0 6px 24px rgba(0,0,0,.2)}
.btn-black:hover{background:#222;transform:translateY(-2px)}
.btn-outline{background:transparent;color:var(–navy);border:2px solid var(–navy)}
.btn-outline:hover{background:var(–navy);color:#fff;transform:translateY(-2px)}
.btn-ghost{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.35)}
.btn-ghost:hover{border-color:#fff;background:rgba(255,255,255,.12);transform:translateY(-2px)}
.btn-sm{padding:12px 24px;font-size:13px}
.btn-wide{width:100%;justify-content:center;padding:17px}
.arr{transition:transform .2s}
.btn:hover .arr{transform:translateX(4px)}

/* REVEAL */
.rv{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.rv.lft{transform:translateX(-34px)}.rv.rgt{transform:translateX(34px)}
.rv.vis{opacity:1;transform:none}
.no-js .rv,.rv.fallback{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

/* NAV */
#nav{position:fixed;inset:0 0 auto;z-index:999;height:78px;padding:0 5%;
display:flex;align-items:center;justify-content:space-between;transition:all .4s}
#nav.sol{background:rgba(255,255,255,.97);box-shadow:0 1px 0 var(–line),0 6px 32px rgba(0,0,0,.06);
backdrop-filter:blur(20px);height:68px}
.nl img{height:56px;width:auto}
.nlinks{display:flex;gap:32px;list-style:none}
.nlinks a{font-size:13.5px;font-weight:500;color:rgba(255,255,255,.8);
position:relative;padding-bottom:3px;transition:color .2s}
.nlinks a::after{content:’’;position:absolute;bottom:0;left:0;right:0;height:2px;
background:var(–green);transform:scaleX(0);transition:transform .25s}
.nlinks a:hover,.nlinks a.act{color:#fff}
.nlinks a:hover::after,.nlinks a.act::after{transform:scaleX(1)}
#nav.sol .nlinks a{color:var(–body)}
#nav.sol .nlinks a:hover,#nav.sol .nlinks a.act{color:var(–navy)}
.nr{display:flex;align-items:center;gap:18px}
.nph{font-size:13px;font-weight:600;color:rgba(255,255,255,.85);display:flex;align-items:center;gap:6px}
#nav.sol .nph{color:var(–navy)}
.burger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px}
.burger span{display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:all .3s}
#nav.sol .burger span{background:var(–navy)}

/* MOBILE NAV */
.mob{display:none;position:fixed;inset:0;z-index:998;background:var(–black);
flex-direction:column;align-items:center;justify-content:center;gap:28px}
.mob.open{display:flex}
.mob a{font-size:26px;font-weight:700;color:#fff;font-family:var(–fd);transition:color .2s}
